-    swapchainCreateInfo.compositeAlpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR;
+    // Mali-G615 and many other Android GPUs don't support OPAQUE composite
+    // alpha — the compositor handles alpha via INHERIT. Hard-coding OPAQUE
+    // causes the driver to accept the swapchain in a degraded blending mode
+    // → flickering + heavy frame stalls (game drops to ~20 FPS on Mali).
+    // Fall back through the supported bits in preference order.
+    {
+        VkCompositeAlphaFlagBitsKHR caCandidates[] = {
+            VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR,
+            VK_COMPOSITE_ALPHA_INHERIT_BIT_KHR,
+            VK_COMPOSITE_ALPHA_PRE_MULTIPLIED_BIT_KHR,
+            VK_COMPOSITE_ALPHA_POST_MULTIPLIED_BIT_KHR,
+        };
+        swapchainCreateInfo.compositeAlpha = caCandidates[0];
+        for (Uint32 i = 0; i < SDL_arraysize(caCandidates); i++) {
+            if (swapchainSupportDetails.capabilities.supportedCompositeAlpha & caCandidates[i]) {
+                swapchainCreateInfo.compositeAlpha = caCandidates[i];
+                break;
+            }
+        }
+    }
     swapchainCreateInfo.presentMode = SDLToVK_PresentMode[windowData->presentMode];
